{
  "name": "kiro-evolve",
  "description": "Default agent with Kiro Evolve conversation learning",
  "tools": ["*"],
  "allowedTools": ["fs_read", "todo_list", "use_subagent", "grep"],
  "resources": [
    "file://README.md",
    "file://KIRO.md",
    "file://.kiro/rules/**/*.md",
    "file://$HOME/.kiro/knowledge/evolved/*.md"
  ],
  "hooks": {
    "agentSpawn": [
      {"command": "bash $HOME/.kiro/hooks/check-review.sh"},
      {"command": "bash $HOME/.kiro/hooks/check-dream.sh"},
      {"command": "bash $HOME/.kiro/hooks/check-cleanup.sh"},
      {"command": "bash $HOME/.kiro/hooks/check-language-review.sh"},
      {"command": "bash $HOME/.kiro/hooks/check-language-dream.sh"},
      {"command": "bash $HOME/.kiro/hooks/check-language-cleanup.sh"}
    ],
    "userPromptSubmit": [
      {"command": "bash $HOME/.kiro/hooks/save-transcript.sh"},
      {"command": "bash $HOME/.kiro/hooks/save-language-transcript.sh"}
    ],
    "stop": [
      {"command": "bash $HOME/.kiro/hooks/save-transcript.sh"},
      {"command": "bash $HOME/.kiro/hooks/save-language-transcript.sh"}
    ]
  },
  "toolsSettings": {
    "execute_bash": {
      "autoAllowReadonly": true
    }
  },
  "useLegacyMcpJson": true
}
